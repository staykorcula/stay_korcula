# ===========================================
# Contact Form – Resend
# ===========================================
# Copy to .env or .env.local and fill in your values.
#
# 1. Sign up at https://resend.com (free: 100 emails/day)
# 2. Create API key at https://resend.com/api-keys
# 3. Verify your domain to send from your own address
# ===========================================

RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: Sender address (default: onboarding@resend.dev for testing)
# When using a verified domain: "StayKorčula <noreply@yourdomain.com>"
# RESEND_FROM_EMAIL=StayKorčula <onboarding@resend.dev>

# Recipient for all form submissions
TO_EMAIL=staykorcula@gmail.com
